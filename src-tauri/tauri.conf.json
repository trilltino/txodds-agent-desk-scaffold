{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "World Cup Agent Desk",
  "version": "0.1.0",
  "identifier": "fun.superteam.txodds-agent-desk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:desktop",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "World Cup Agent Desk",
        "width": 1320,
        "height": 920,
        "minWidth": 980,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../sidecars/coralos-bridge.mjs",
      "../sidecars/yellowstone-bridge.mjs",
      "../sidecars/bin/node.exe",
      "../node_modules/@grpc",
      "../node_modules/@js-sdsl",
      "../node_modules/@protobufjs",
      "../node_modules/@triton-one",
      "../node_modules/base-x",
      "../node_modules/bs58",
      "../node_modules/lodash.camelcase",
      "../node_modules/long",
      "../node_modules/protobufjs"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
